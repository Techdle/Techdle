# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Build-time generated puzzle data (regenerated on each build)
/src/data/puzzles/client-puzzles.json
/src/data/puzzles/answer-hashes.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
