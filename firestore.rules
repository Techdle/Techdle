rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Optimized Single-Doc Schema ─────────────────────────────
    // Each user has exactly one document: /users/{userId}
    // Contains: stats (UserStats) + history (compact string array)
    // No subcollections — one read per session, one write per game.

    match /users/{userId} {
      // Users can only read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Validate the document structure on write
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['stats', 'history', 'updatedAt']);
    }
  }
}
